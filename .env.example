# Appwrite Cloud
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=
NEXT_PUBLIC_APPWRITE_DATABASE_ID=grindkit
APPWRITE_API_KEY=

# Web Push — generate once with:  pnpm dlx web-push generate-vapid-keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:you@example.com

# Random long string. Vercel Cron will attach this as
# `Authorization: Bearer $CRON_SECRET` when calling /api/cron/notifications.
CRON_SECRET=
